# Database - Railway provides DATABASE_URL for PostgreSQL
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Session secret - use a long random string in production (min 32 chars)
SESSION_SECRET="your-super-secret-key-at-least-32-characters-long"

# Password reset emails (Resend) - get API key at https://resend.com
# RESEND_API_KEY=re_xxxxxxxxxxxx
# FROM_EMAIL=onboarding@resend.dev
# SITE_URL=https://yoursite.com

# Optional: override default admin/user credentials when seeding
# ADMIN_EMAIL=admin@brianmoses.com
# ADMIN_PASSWORD=change-this
# USER_EMAIL=user@brianmoses.com
# USER_PASSWORD=change-this

# Optional: Cloudinary for image uploads (recommended for production/Railway)
# Without these, uploads go to public/uploads/ (lost on redeploy)
# Get credentials: https://cloudinary.com/console
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
# Or separately:
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
